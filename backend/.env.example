NODE_ENV=production
PORT=3000
PUBLIC_URL=https://tasks.2090.fun

JWT_SECRET=CHANGE_ME_LONG_RANDOM_HEX_32_BYTES
ACCESS_TOKEN_TTL_SECONDS=900

DATABASE_URL=postgresql://taskhub:CHANGE_ME_DB_PASS@taskhub-db:5432/taskhub

REDIS_HOST=taskhub-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS
REDIS_DB=0

SENDPULSE_API_USER_ID=CHANGE_ME
SENDPULSE_API_SECRET=CHANGE_ME
SENDPULSE_SENDER_EMAIL=noreply@2090.fun
SENDPULSE_SENDER_NAME=Система поручений

MAX_OAUTH_CLIENT_ID=
MAX_OAUTH_CLIENT_SECRET=
MAX_OAUTH_REDIRECT_URI=https://tasks.2090.fun/auth/max/callback
MAX_BOT_USERNAME=
MAX_BOT_TOKEN=
MAX_BOT_WEBHOOK_SECRET=
MAX_BOT_API_BASE_URL=https://platform-api2.max.ru
MAX_MINI_APP_INIT_DATA_TTL_SECONDS=300

BACKUP_MODE=required
RESTIC_REPOSITORY=s3:https://CHANGE_ME_OFFSITE_ENDPOINT/CHANGE_ME_BUCKET/taskhub-restic
RESTIC_PASSWORD=CHANGE_ME_LONG_RANDOM_RESTIC_PASSWORD
BACKUP_TMP_DIR=/tmp/taskhub-backup

S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=task-hub-backups
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=true

REMINDER_FAR_SECONDS=86400
REMINDER_NEAR_SECONDS=7200
REMINDER_CHECK_WINDOW_SECONDS=300

LIMIT_ATTACHMENT_MAX_BYTES=26214400
LIMIT_AVATAR_MAX_BYTES=5242880
LIMIT_MAX_ATTACHMENTS_PER_MESSAGE=10
LIMIT_MESSAGE_TEXT_MAX_LENGTH=4000
LIMIT_TASK_TITLE_MAX_LENGTH=200
LIMIT_TASK_DESCRIPTION_MAX_LENGTH=5000
LIMIT_MAX_ASSIGNEES_PER_TASK=100
LIMIT_PASSWORD_MIN_LENGTH=8
LIMIT_PASSWORD_MAX_LENGTH=128
LIMIT_MESSAGE_COUNTER_CAP=9999
LIMIT_LOGIN_MAX_FAILED_ATTEMPTS=5
LIMIT_LOGIN_LOCKOUT_SECONDS=900
LIMIT_PASSWORD_SETUP_TTL_SECONDS=86400
LIMIT_RATE_LIMIT_MAX_REQUESTS=10
LIMIT_RATE_LIMIT_WINDOW_SECONDS=60

STORAGE_DIR=/data/attachments
