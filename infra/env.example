# Copy to .env; fill via Docker secrets in production. NO real values here.
ENVIRONMENT=production
SECRET_KEY=__set_via_secret__
DATABASE_URL=postgresql+asyncpg://taskhub@pgbouncer:6432/taskhub
ALEMBIC_DATABASE_URL=postgresql+asyncpg://taskhub@postgres:5432/taskhub
REDIS_URL=redis://redis:6379/0
SENDPULSE_CLIENT_ID=__set_via_secret__
SENDPULSE_CLIENT_SECRET=__set_via_secret__
SENDPULSE_FROM_EMAIL=noreply@example.com
COOKIE_SECURE=true
